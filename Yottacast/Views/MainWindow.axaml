<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Yottacast.ViewModels"
        xmlns:conv="using:Avalonia.Data.Converters"
        x:Class="Yottacast.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Yottacast"
        Width="{DynamicResource Theme.WindowWidth}"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False">

    <Window.Styles>
        <!-- Strip all default TextBox chrome -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BoxShadow" Value="none"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BoxShadow" Value="none"/>
        </Style>
        <!-- Placeholder text -->
        <Style Selector="TextBox /template/ TextBlock[Name=PART_Watermark]">
            <Setter Property="Foreground" Value="{DynamicResource Theme.SearchPlaceholder}"/>
        </Style>

        <!-- ListBox chrome -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource Theme.CornerRadiusItem}"/>
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.ItemHover}"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.ItemSelection}"/>
        </Style>
        <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.ItemSelectionHover}"/>
        </Style>
        <!-- Keep text visible on selection -->
        <Style Selector="ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.ItemSelectionText}"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.icon-box">
            <Setter Property="Background" Value="{DynamicResource Theme.ItemSelectionIconBackground}"/>
        </Style>
    </Window.Styles>

    <Border Margin="28"
            CornerRadius="{DynamicResource Theme.CornerRadiusWindow}"
            Background="{DynamicResource Theme.WindowBackground}">
        <DockPanel>

            <!-- ── Search row ── -->
            <Grid DockPanel.Dock="Top"
                  ColumnDefinitions="Auto,*,Auto"
                  Margin="18,0"
                  Height="64">

                <!-- Magnifier icon -->
                <PathIcon Grid.Column="0"
                          Width="19" Height="19"
                          Margin="0,0,12,0"
                          Foreground="{DynamicResource Theme.Icon}"
                          VerticalAlignment="Center"
                          Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>

                <!-- Search input -->
                <TextBox Grid.Column="1"
                         x:Name="SearchBox"
                         Text="{Binding SearchText}"
                         Watermark="Search for apps, files, commands…"
                         FontSize="{DynamicResource Theme.FontSizeSearch}"
                         FontWeight="Regular"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         Foreground="{DynamicResource Theme.SearchText}"
                         CaretBrush="{DynamicResource Theme.SearchCaret}"
                         SelectionBrush="{DynamicResource Theme.SearchSelection}"/>

                <!-- ESC badge (visible only when input is empty) -->
                <Border Grid.Column="2"
                        Background="{DynamicResource Theme.EscBadgeBackground}"
                        CornerRadius="{DynamicResource Theme.CornerRadiusEsc}"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        IsVisible="{Binding SearchText, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                    <TextBlock Text="ESC"
                               Foreground="{DynamicResource Theme.EscBadgeText}"
                               FontSize="{DynamicResource Theme.FontSizeSmall}"
                               FontWeight="Medium"/>
                </Border>
            </Grid>

            <!-- ── Divider ── -->
            <Rectangle DockPanel.Dock="Top"
                       Height="1"
                       Fill="{DynamicResource Theme.Divider}"
                       IsVisible="{Binding HasResults}"/>

            <!-- ── No results ── -->
            <Border DockPanel.Dock="Top"
                    Padding="0,28,0,28"
                    IsVisible="{Binding ShowNoResults}">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="No results"
                               Foreground="{DynamicResource Theme.NoResultsTitle}"
                               FontSize="{DynamicResource Theme.FontSizeNoResults}"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Try a different search term"
                               Foreground="{DynamicResource Theme.NoResultsSubtitle}"
                               FontSize="{DynamicResource Theme.FontSizeTitle}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ── Results list ── -->
            <ListBox DockPanel.Dock="Top"
                     ItemsSource="{Binding Results}"
                     SelectedItem="{Binding SelectedResult}"
                     MaxHeight="416"
                     Padding="8,6"
                     IsVisible="{Binding HasResults}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ResultItemViewModel">
                        <Grid ColumnDefinitions="Auto,*,Auto" MinHeight="44">

                            <!-- Icon box -->
                            <Border Grid.Column="0"
                                    Classes="icon-box"
                                    Width="36" Height="36"
                                    CornerRadius="{DynamicResource Theme.CornerRadiusIcon}"
                                    Background="{DynamicResource Theme.ItemIconBackground}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0">
                                <TextBlock Text="{Binding Icon}"
                                           FontSize="17"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Title + subtitle -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Vertical"
                                        VerticalAlignment="Center"
                                        Spacing="2">
                                <TextBlock Text="{Binding Title}"
                                           Foreground="{DynamicResource Theme.ItemTitle}"
                                           FontSize="{DynamicResource Theme.FontSizeTitle}"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{Binding Subtitle}"
                                           Foreground="{DynamicResource Theme.ItemSubtitle}"
                                           FontSize="{DynamicResource Theme.FontSizeSubtitle}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Category + shortcut -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Spacing="8"
                                        Margin="12,0,0,0">
                                <TextBlock Text="{Binding Category}"
                                           Foreground="{DynamicResource Theme.ItemCategory}"
                                           FontSize="{DynamicResource Theme.FontSizeSmall}"
                                           VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource Theme.ItemShortcutBackground}"
                                        CornerRadius="{DynamicResource Theme.CornerRadiusShortcut}"
                                        Padding="7,3"
                                        IsVisible="{Binding Shortcut, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding Shortcut}"
                                               Foreground="{DynamicResource Theme.ItemShortcutText}"
                                               FontSize="{DynamicResource Theme.FontSizeSmall}"/>
                                </Border>
                            </StackPanel>

                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- ── Footer ── -->
            <Border DockPanel.Dock="Bottom"
                    Padding="18,7"
                    BorderBrush="{DynamicResource Theme.FooterBorder}"
                    BorderThickness="0,1,0,0"
                    IsVisible="{Binding HasResults}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                        <TextBlock Foreground="{DynamicResource Theme.FooterText}"
                                   FontSize="{DynamicResource Theme.FontSizeSmall}">
                            <Run Text="{Binding Results.Count}"/>
                            <Run Text="results"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="↑↓  navigate"  Foreground="{DynamicResource Theme.FooterText}" FontSize="{DynamicResource Theme.FontSizeSmall}"/>
                        <TextBlock Text="↵  open"        Foreground="{DynamicResource Theme.FooterText}" FontSize="{DynamicResource Theme.FontSizeSmall}"/>
                        <TextBlock Text="⌘K  actions"   Foreground="{DynamicResource Theme.FooterText}" FontSize="{DynamicResource Theme.FontSizeSmall}"/>
                    </StackPanel>
                </Grid>
            </Border>

        </DockPanel>
    </Border>

</Window>
